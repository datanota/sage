
# :kivy 2.0.0

<SageContent>:

    ScreenManager:
        id: screen_manager
        canvas:
            Color:
                rgb: 212/255, 213/255, 212/255
            Rectangle:
                pos: self.pos
                size: self.size

##########################################################
########################################################## home screen
##########################################################

        Screen:
            name: 'home'
            BoxLayout:
                orientation: 'vertical'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    padding: '15dp'
                    MDRoundFlatIconButton:
                        name: 'data_home_b'
                        icon: 'copyright'
                        text: '2023 Datanota'
                        font_size: '14sp'
                        pos_hint: {'right': 1, 'top': 1}
                        # pos_hint: {'center_x':.9}
                        on_release:
                            app.sage_ss()
                BoxLayout:
                    orientation: 'vertical'
                    canvas:
                        Color:
                            rgb: 212/255, 213/255, 212/255
                        Rectangle:
                            size: self.size
                            pos: self.pos
                    GridLayout:
                        cols: 2
                        padding: '30dp'
                        BoxLayout:
                            orientation: 'vertical'
                            padding: 0, 0, 0, 50
                            Image:
                                source: '../assets/sage_applogo.png'
                                allow_stretch: True
                            MDFillRoundFlatIconButton:
                                name: 'demo_home_b'
                                icon: 'play-circle'
                                text: 'product demo'
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 1, 1, 1
                                size_hint: 1, None
                                on_release:
                                    app.dn_sage_demo()
                        GridLayout:
                            rows: 6
                            spacing: '15dp'
                            padding: [30, 80, 20, 250]
                            MDLabel:
                                text: 'data-360'
                                halign: 'center'
                                theme_text_color: 'Custom'
                                text_color: 0, 0, 0
                                font_size: '20sp'
                            MDFillRoundFlatIconButton:
                                name: 'l1_b'
                                icon: 'file-excel'
                                text: 'design dataset   '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    screen_manager.current = 's1'
                            MDFillRoundFlatIconButton:
                                name: 'l2_b'
                                icon: 'export'
                                text: 'generate data     '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    screen_manager.current = 's2'
                            MDFillRoundFlatIconButton:
                                name: 'l3_b'
                                icon: 'database'
                                text: 'create database '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    screen_manager.current = 's3'
                            MDFillRoundFlatIconButton:
                                name: 'l4_b'
                                icon: 'text-search'
                                text: 'extract insights   '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    screen_manager.current = 's4'
                            MDFillRoundFlatIconButton:
                                name: 'l4_b'
                                icon: 'finance'
                                text: 'analytics              '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    screen_manager.current = 's4'

##########################################################
########################################################## design a dataset
##########################################################

        Screen:
            name: 's1'
            BoxLayout:
                orientation: 'vertical'
                spacing: '0dp'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    padding: '15dp'
                    left_action_items:
                        [
                        ["home", lambda x: app.callback_top_nav('home'), 'home'],
                        ["file-excel", lambda x: app.callback_top_nav('s1'), 'dataset_design'],
                        ["export", lambda x: app.callback_top_nav('s2'), 'data_generation'],
                        ["database", lambda x: app.callback_top_nav('s3'), 'database'],
                        ["text-search", lambda x: app.callback_top_nav('s4'), 'insights']
                        ]
                    right_action_items:
                        [
                        ["copyright", lambda x: app.sage_ss(), '']
                        ]
                BoxLayout:
                    orientation: 'horizontal'
                    spacing: '0dp'
                    padding: '0dp'
                    TabbedPanel:
                        tab_width: (self.parent.width - 10) /3
                        do_default_tab: False
                        tab_pos: 'bottom_mid'
                        background_image: ''
                        background_color: 212/255, 213/255, 212/255
                        TabbedPanelItem:
                            id: s1_s1
                            text: 'activity-to-data'
                            bold: True
                            color: 131/255, 171/255, 160/255
                            background_down: ''
                            GridLayout:
                                rows: 2
                                BoxLayout:
                                    orientation: 'horizontal'
                                    size_hint: 1, 0.25
                                    canvas:
                                        Color:
                                            rgb: 131/255, 173/255, 160/255
                                        Rectangle:
                                            size: self.size
                                            pos:self.pos
                                    MDLabel:
                                        text: 'Design a Dataset - Shopping Data'
                                        halign: 'center'
                                        theme_text_color: 'Custom'
                                        text_color: 0, 0, 0
                                        font_size: 60
                                        padding_x: '50dp'
                                        size_hint: 1, 1
                                BoxLayout:
                                    orientation: 'vertical'
                                    Image:
                                        source: '../assets/design_dataset_s1.png'
                                        allow_stretch: True
                        TabbedPanelItem:
                            id: s1_s2
                            text: 'attributes'
                            bold: True
                            color: 131/255, 171/255, 160/255
                            background_down: ''
                            BoxLayout:
                                orientation: 'vertical'
                                Image:
                                    source: '../assets/design_dataset_s2.png'
                                    allow_stretch: True
                        TabbedPanelItem:
                            id: s1_s3
                            text: 'attribute-variable-type'
                            bold: True
                            color: 131/255, 171/255, 160/255
                            background_down: ''
                            BoxLayout:
                                orientation: 'vertical'
                                Image:
                                    source: '../assets/design_dataset_s3.png'
                                    allow_stretch: True

##########################################################
########################################################## generate data
##########################################################

        Screen:
            name: 's2'
            BoxLayout:
                orientation: 'vertical'
                spacing: '0dp'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    padding: '15dp'
                    left_action_items:
                        [
                        ["home", lambda x: app.callback_top_nav('home'), 'home'],
                        ["file-excel", lambda x: app.callback_top_nav('s1'), 'dataset_design'],
                        ["export", lambda x: app.callback_top_nav('s2'), 'data_generation'],
                        ["database", lambda x: app.callback_top_nav('s3'), 'database'],
                        ["text-search", lambda x: app.callback_top_nav('s4'), 'insights']
                        ]
                    right_action_items:
                        [
                        ["copyright", lambda x: app.sage_ss(), '']
                        ]
                GridLayout:
                    cols: 2
                    canvas:
                        Color:
                            rgb: 212/255, 213/255, 212/255
                        Rectangle:
                            size: self.size
                            pos: self.pos
                    BoxLayout:
                        orientation: 'vertical'
                        GridLayout:
                            rows: 3
                            spacing: '20dp'
                            padding: '10dp'
                            StackLayout:
                                orientation: 'lr-tb'
                                size_hint: 1, 0.2
                                spacing: '10dp'
                                MDTextFieldRect:
                                    id: num_customers
                                    multiline: False
                                    cursor_color: 196/255, 204/255, 217/255
                                    hint_text: 'How many customers?'
                                    input_filter: 'int'
                                    padding_y: '10dp'
                                    hint_text_color: 149/255, 158/255, 167/255
                                    on_text: self.foreground_color = 196/255, 204/255, 217/255
                                    size_hint: 0.35, None
                                    height: '50dp'
                                    color: 196/255, 204/255, 217/255
                                    font_size: '20sp'
                                    background_normal: ''
                                    background_color: 90/255, 101/255, 108/255
                                MDTextFieldRect:
                                    id: num_products
                                    multiline: False
                                    cursor_color: 196/255, 204/255, 217/255
                                    hint_text: 'How many products?'
                                    input_filter: 'int'
                                    padding_y: '10dp'
                                    hint_text_color: 149/255, 158/255, 167/255
                                    on_text: self.foreground_color = 196/255, 204/255, 217/255
                                    size_hint: 0.35, None
                                    height: '50dp'
                                    color: 196/255, 204/255, 217/255
                                    font_size: '20sp'
                                    background_normal: ''
                                    background_color: 90/255, 101/255, 108/255
                                Button:
                                    name: 'data_check_b'
                                    icon: 'check-circle'
                                    text: 'check data'
                                    color: 0, 0, 0
                                    font_size: '20sp'
                                    size_hint: 0.30, None
                                    height: '50dp'
                                    background_normal: ''
                                    background_color: 131/255, 173/255, 160/255
                                    on_release:
                                        app.data_input_check()
                            BoxLayout:
                                orientation: 'horizontal'
                                id: data_input_check
                                spacing: '20dp'
                                padding: [0, 0, 0, 300]
                            BoxLayout:
                                orientation: 'horizontal'
                                id: data_preview

##########################################################
########################################################## build a database
##########################################################

        Screen:
            name: 's3'
            BoxLayout:
                orientation: 'vertical'
                spacing: '0dp'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    padding: '15dp'
                    left_action_items:
                        [
                        ["home", lambda x: app.callback_top_nav('home'), 'home'],
                        ["file-excel", lambda x: app.callback_top_nav('s1'), 'dataset_design'],
                        ["export", lambda x: app.callback_top_nav('s2'), 'data_generation'],
                        ["database", lambda x: app.callback_top_nav('s3'), 'database'],
                        ["text-search", lambda x: app.callback_top_nav('s4'), 'insights']
                        ]
                    right_action_items:
                        [
                        ["copyright", lambda x: app.sage_ss(), '']
                        ]
                BoxLayout:
                    orientation: 'horizontal'
                    canvas:
                        Color:
                            rgb: 212/255, 213/255, 212/255
                        Rectangle:
                            size: self.size
                            pos: self.pos
                    GridLayout:
                        rows: 2
                        BoxLayout:
                            orientation: 'vertical'
                            Image:
                                source: '../assets/db_schema_s.png'
                                allow_stretch: True
                        BoxLayout:
                            orientation: 'vertical'
                            id: db_outcome
                            spacing: '20dp'
                            padding: [100, 0, 100, 150]
                            size_hint: 1, 0.3
                            Button:
                                icon: 'check-circle'
                                text: 'create database'
                                color: 0, 0, 0
                                font_size: '20sp'
                                # size_hint: 1, 1
                                # height: '30dp'
                                background_normal: ''
                                background_color: 131/255, 173/255, 160/255
                                on_release:
                                    app.create_database()

##########################################################
########################################################## insights
##########################################################

        Screen:
            name: 's4'
            BoxLayout:
                orientation: 'vertical'
                spacing: '0dp'

                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    padding: '15dp'
                    left_action_items:
                        [
                        ["home", lambda x: app.callback_top_nav('home'), 'home'],
                        ["file-excel", lambda x: app.callback_top_nav('s1'), 'dataset_design'],
                        ["export", lambda x: app.callback_top_nav('s2'), 'data_generation'],
                        ["database", lambda x: app.callback_top_nav('s3'), 'database'],
                        ["text-search", lambda x: app.callback_top_nav('s4'), 'insights']
                        ]
                    right_action_items:
                        [
                        ["copyright", lambda x: app.sage_ss(), '']
                        ]
                BoxLayout:
                    orientation: 'horizontal'
                    spacing: '0dp'
                    padding: '0dp'
                    TabbedPanel:
                        tab_width: (self.parent.width - 10) /11
                        do_default_tab: False
                        tab_pos: 'bottom_mid'
                        background_image: ''
                        background_color: 212/255, 213/255, 212/255
                        TabbedPanelItem:
                            text: 'db'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            GridLayout:
                                rows: 2
                                BoxLayout:
                                    orientation: 'horizontal'
                                    size_hint: 1, 0.25
                                    canvas:
                                        Color:
                                            rgb: 131/255, 173/255, 160/255
                                        Rectangle:
                                            size: self.size
                                            pos:self.pos
                                    MDLabel:
                                        text: 'Shopping Database Schema'
                                        halign: 'center'
                                        theme_text_color: 'Custom'
                                        text_color: 81/255, 81/255, 81/255
                                        font_size: 90
                                        padding_x: '50dp'
                                        size_hint: 1, 1
                                BoxLayout:
                                    orientation: 'vertical'
                                    Image:
                                        source: '../assets/db_schema_s.png'
                                        allow_stretch: True
                        TabbedPanelItem:
                            text: 'test'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            BoxLayout:
                                orientation: 'vertical'
                                BoxLayout:
                                    orientation: 'horizontal'
                                    padding: '4dp'
                                    size_hint: 1,0.2
                                    MDLabel:
                                        text: '    test run any query against shopping database'
                                        halign: 'left'
                                        font_size: '16sp'
                                    MDIconButton:
                                        name: 'key'
                                        icon: 'key-variant'
                                        icon_size: "44sp"
                                        theme_icon_color: "Custom"
                                        icon_color: 215/255, 163/255, 9/255
                                        pos_hint: {'center_x':.5,'center_y':.7}
                                        on_release:
                                            app.tip_dialog('Generic Query Samples:', '''
                                            1. by default this is connected to shopping.db
                                            2. list tables: SELECT name FROM sqlite_master WHERE type='table';
                                            3. check table metadata: PRAGMA table_info('table_name');
                                            4. select * from table_name;
                                            ''')
                                BoxLayout:
                                    orientation: 'vertical'
                                    padding: '5dp'
                                    MDTextFieldRect:
                                        id: query_box
                                        cursor_color: 0, 0, 0
                                        hint_text: ' write query here'
                                        on_text: self.foreground_color = 0, 0, 0
                                        color: 1, 0, 1
                                        font_size: '16sp'
                                        background_normal: ''
                                        background_color: 1, 1, 1
                                    Button:
                                        text: 'run query'
                                        color: 211/255, 217/255, 208/255
                                        font_size: '20sp'
                                        size_hint: 0.2, 0.2
                                        pos_hint: {'right':1,'center_y':1}
                                        background_normal: ''
                                        background_color: 69/255, 92/255, 100/255
                                        on_release:
                                            app.test_run_queries()
                                    BoxLayout:
                                        orientation: 'vertical'
                                        id: query_results
                        TabbedPanelItem:
                            text: 'Q1'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q1')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q1
                        TabbedPanelItem:
                            text: 'Q2'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q2')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q2
                        TabbedPanelItem:
                            text: 'Q3'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q3')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q3
                        TabbedPanelItem:
                            text: 'Q4'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q4')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q4
                        TabbedPanelItem:
                            text: 'Q5'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q5')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q5
                        TabbedPanelItem:
                            text: 'Q6'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q6')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q6
                        TabbedPanelItem:
                            text: 'Q7'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q7')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q7
                        TabbedPanelItem:
                            text: 'Q8'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q8')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q8
                        TabbedPanelItem:
                            text: 'Q9'
                            color: 215/255, 163/255, 9/255
                            background_down: ''
                            on_release:
                                app.insight_questions_screen('q9')
                            BoxLayout:
                                orientation: 'vertical'
                                id: q9



