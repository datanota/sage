
    # :kivy 2.0.0

<SageInsightContent>:

    ScreenManager:
        id: screen_manager
        canvas:
            Color:
                rgb: 212/255, 213/255, 212/255
            Rectangle:
                pos: self.pos
                size: self.size

##########################################################
########################################################## home screen
##########################################################

        Screen:
            name: 'insights_home'
            BoxLayout:
                orientation: 'vertical'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    BoxLayout:
                        orientation: 'horizontal'
                        padding: [10, 0, 0, 25]
                        GridLayout:
                            cols: 2
                            BoxLayout:
                                orientation: 'horizontal'
                                spacing: '10dp'
                                MDRoundFlatIconButton:
                                    icon: 'format-size'
                                    text: 'window_size'
                                    font_size: '14sp'
                                    on_release:
                                        app.selection_dropdown(self, 'navbar')
                                MDRoundFlatIconButton:
                                    id: engine_drop_down
                                    icon: 'database'
                                    text: 'engine'
                                    font_size: '14sp'
                                    on_release:
                                        app.selection_dropdown(self, 'navbar')
                        MDRoundFlatIconButton:
                            icon: 'copyright'
                            text: app.get_current_year('Datanota')
                            font_size: '14sp'
                            on_release:
                                app.sage_window_ss('sage.png')
                BoxLayout:
                    orientation: 'vertical'
                    id: main
                    canvas:
                        Color:
                            rgb: 212/255, 213/255, 212/255
                        Rectangle:
                            size: self.size
                            pos: self.pos
                    GridLayout:
                        cols: 2
                        padding: '30dp'
                        BoxLayout:
                            orientation: 'vertical'
                            padding: 0, 0, 0, 50
                            Image:
                                source: app.get_assets_path('sage_applogo.png')
                                allow_stretch: True
                        GridLayout:
                            rows: 4
                            spacing: '15dp'
                            padding: [30, 200, 20, 100]
                            ######################### a generic function is called for each section Q & A
                            ######################### the extra space in button text string is to alight section names
                            MDFillRoundFlatIconButton:
                                icon: 'numeric-1-box'
                                text: 'descriptive  '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    app.get_section_screen('descriptive')
                            MDFillRoundFlatIconButton:
                                icon: 'numeric-2-box'
                                text: 'comparative'
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    app.get_section_screen('comparative')
                            MDFillRoundFlatIconButton:
                                icon: 'numeric-3-box'
                                text: 'derived         '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    app.get_section_screen('derived')
                            MDFillRoundFlatIconButton:
                                icon: 'play-circle'
                                text: 'product demo  '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 1, 1, 1
                                size_hint: 1, None
                                on_release:
                                    app.dn_sage_demo()

##########################################################
########################################################## section screen
##########################################################

        Screen:
            name: 'section_screen'
            BoxLayout:
                orientation: 'vertical'
                spacing: '0dp'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    padding: '15dp'
                    left_action_items:
                        [
                        ['home', lambda x: app.callback_top_nav('insights_home'), 'home']
                        ]
                    right_action_items:
                        [
                        ["copyright", lambda x: app.sage_ss('window'), '']
                        ]
                TabbedPanel:
                    id: q_tabs
                    tab_width: (self.parent.width - 10) /11
                    do_default_tab: False
                    tab_pos: 'bottom_mid'
                    background_image: ''
                    background_color: 212/255, 213/255, 212/255


