
# :kivy 2.0.0

##########################################################
########################################################## insights - level_1
##########################################################

<Level1>:
    name: 'is1'
    BoxLayout:
        orientation: 'vertical'
        spacing: '0dp'
        MDTopAppBar:
            md_bg_color: app.theme_cls.primary_dark
            specific_text_color: app.theme_cls.primary_light
            elevation: 1
            padding: '15dp'
            left_action_items:
                [
                ["home", lambda x: app.callback_top_nav('home'), 'home'],
                ["numeric-1-box", lambda x: app.callback_top_nav('is1'), 'level_1'],
                ["numeric-2-box", lambda x: app.callback_top_nav('is2'), 'level_2'],
                ["numeric-3-box", lambda x: app.callback_top_nav('is3'), 'level_3']
                ]
            right_action_items:
                [
                ["copyright", lambda x: app.sage_ss(), '']
                ]
        BoxLayout:
            orientation: 'horizontal'
            spacing: '0dp'
            padding: '0dp'
            TabbedPanel:
                tab_width: (self.parent.width - 10) /11
                do_default_tab: False
                tab_pos: 'bottom_mid'
                background_image: ''
                background_color: 212/255, 213/255, 212/255
                TabbedPanelItem:
                    text: 'db'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    GridLayout:
                        rows: 2
                        BoxLayout:
                            orientation: 'horizontal'
                            size_hint: 1, 0.25
                            canvas:
                                Color:
                                    rgb: 131/255, 173/255, 160/255
                                Rectangle:
                                    size: self.size
                                    pos:self.pos
                            MDLabel:
                                text: 'Level One: SQLite3 Database'
                                halign: 'center'
                                theme_text_color: 'Custom'
                                text_color: 81/255, 81/255, 81/255
                                font_size: 90
                                padding_x: '50dp'
                                size_hint: 1, 1
                            MDIconButton:
                                name: 'key'
                                icon: 'key-variant'
                                icon_size: "44sp"
                                padding: [0, 50, 20, 0]
                                theme_icon_color: "Custom"
                                icon_color: 215/255, 163/255, 9/255
                                pos_hint: {'center_x':.5,'center_y':.7}
                                on_release:
                                    app.tip_dialog('Generic Query Samples:', '''
                                    1. by default this is connected to shopping.db
                                    2. list tables: SELECT name FROM sqlite_master WHERE type='table';
                                    3. check table metadata: PRAGMA table_info('table_name');
                                    4. select * from table_name;
                                    ''', app.theme_cls.primary_color)
                        BoxLayout:
                            orientation: 'vertical'
                            MDTextFieldRect:
                                id: query_box
                                cursor_color: 0, 0, 0
                                hint_text: ' check database schema and tables'
                                on_text: self.foreground_color = 0, 0, 0
                                color: 1, 0, 1
                                font_size: '16sp'
                                background_normal: ''
                                background_color: 1, 1, 1
                            Button:
                                text: 'run query'
                                color: 211/255, 217/255, 208/255
                                font_size: '20sp'
                                size_hint: 0.2, 0.2
                                pos_hint: {'right':1,'center_y':1}
                                background_normal: ''
                                background_color: 69/255, 92/255, 100/255
                                on_release:
                                    app.check_db_schema()
                            BoxLayout:
                                orientation: 'vertical'
                                id: query_results
                TabbedPanelItem:
                    text: 'Q1'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q1')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q1
                TabbedPanelItem:
                    text: 'Q2'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q2')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q2
                TabbedPanelItem:
                    text: 'Q3'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q3')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q3
                TabbedPanelItem:
                    text: 'Q4'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q4')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q4
                TabbedPanelItem:
                    text: 'Q5'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q5')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q5
                TabbedPanelItem:
                    text: 'Q6'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q6')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q6
                TabbedPanelItem:
                    text: 'Q7'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q7')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q7
                TabbedPanelItem:
                    text: 'Q8'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q8')
                    BoxLayout:
                        orientation: 'vertical'
                        id: q8
                TabbedPanelItem:
                    text: 'Q9'
                    color: 215/255, 163/255, 9/255
                    background_down: ''
                    on_release:
                        app.insight_questions_screen('q9')
                    BoxLayout:
                        orientation: 'vertical'
