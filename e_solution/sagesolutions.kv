
# :kivy 2.0.0
#:include amber.kv

<SageSolutionsContent>:

    ScreenManager:
        id: screen_manager
        canvas:
            Color:
                rgb: 212/255, 213/255, 212/255
            Rectangle:
                pos: self.pos
                size: self.size

##########################################################
########################################################## home screen
##########################################################

        Screen:
            name: 'solution_home'
            BoxLayout:
                orientation: 'vertical'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    BoxLayout:
                        orientation: 'horizontal'
                        padding: [10, 0, 0, 25]
                        GridLayout:
                            cols: 2
                            BoxLayout:
                                orientation: 'horizontal'
                                spacing: '10dp'
                                MDRoundFlatIconButton:
                                    icon: 'format-size'
                                    text: 'window_size'
                                    font_size: '14sp'
                                    on_release:
                                        app.selection_dropdown(self, 'navbar')
                        MDRoundFlatIconButton:
                            icon: 'copyright'
                            text: app.get_current_year('Datanota')
                            font_size: '14sp'
                            on_release:
                                app.sage_window_ss('sage.png')
                BoxLayout:
                    orientation: 'vertical'
                    id: main
                    canvas:
                        Color:
                            rgb: 212/255, 213/255, 212/255
                        Rectangle:
                            size: self.size
                            pos: self.pos
                    GridLayout:
                        cols: 2
                        padding: '30dp'
                        BoxLayout:
                            orientation: 'vertical'
                            padding: 0, 0, 0, 50
                            Image:
                                source: app.get_assets_path('sage_applogo.png')
                                allow_stretch: True
                        GridLayout:
                            rows: 4
                            spacing: '15dp'
                            padding: [30, 100, 20, 100]
                            MDFillRoundFlatIconButton:
                                icon: 'scatter-plot'
                                text: 'regression          '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    app.populate_solution_section('regression')
                            MDFillRoundFlatIconButton:
                                icon: 'sort'
                                text: 'classification      '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    app.populate_solution_section('classification')
                            MDFillRoundFlatIconButton:
                                icon: 'thumb-up'
                                text: 'recommendation'
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    app.populate_solution_section('recommendation')
                            MDFillRoundFlatIconButton:
                                id: prototype_selection
                                icon: 'shape-square-plus'
                                text: 'prototypes            '
                                icon_color: 0, 0, 0
                                text_color: 0, 0, 0
                                font_size: '20sp'
                                md_bg_color: 131/255, 173/255, 160/255
                                size_hint_x: 0.97
                                on_release:
                                    app.prototype_list(self)

##########################################################
########################################################## solution screen
##########################################################

        Screen:
            name: 'solution_screen'
            BoxLayout:
                orientation: 'vertical'
                spacing: '0dp'
                MDTopAppBar:
                    md_bg_color: app.theme_cls.primary_dark
                    specific_text_color: app.theme_cls.primary_light
                    elevation: 1
                    padding: '15dp'
                    left_action_items:
                        [
                        ['home', lambda x: app.callback_top_nav('solution_home'), 'home']
                        ]
                    right_action_items:
                        [
                        ["copyright", lambda x: app.sage_window_ss('sage.png')]
                        ]
                TabbedPanel:
                    id: solution_tabs
                    tab_width: (self.parent.width - 10) / 3
                    do_default_tab: False
                    tab_pos: 'bottom_mid'
                    background_image: ''
                    background_color: 212/255, 213/255, 212/255
                    TabbedPanelItem:
                        id: solutions_default_tab
                        text: ''
                        color: 215 / 255, 163 / 255, 9 / 255
                        background_down: ''
                        BoxLayout:
                            orientation: 'vertical'
                            spacing: '10dp'
                            canvas:
                                Color:
                                    rgb: 155/255, 186/255, 169/255
                                Rectangle:
                                    pos: self.pos
                                    size: self.size
                            MDLabel:
                                id: solution_section_title
                                text: ''
                                halign: 'center'
                                theme_text_color: 'Custom'
                                text_color: 81 / 255, 81 / 255, 81 / 255
                                font_style: 'H4'
                                size_hint: 1, 0.1
                            Image:
                                id: solution_section_default_graph
                                source: app.get_assets_path('sage_2_db/db_schema_s.png')
                                allow_stretch: True
                                # keep_ratio: False
        AmberContent:

